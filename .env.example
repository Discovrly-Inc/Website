# Google Analytics 4
# Create a GA4 property at https://analytics.google.com
# Get your Measurement ID (format: G-XXXXXXXXXX)
# Uncomment the GoogleAnalytics component in app/layout.tsx once ready
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# PostHog Analytics
# Get your key from https://app.posthog.com/settings
# Then initialize in lib/posthog.ts and add the provider to app/layout.tsx
NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
